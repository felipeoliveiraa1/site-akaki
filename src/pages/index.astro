---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ReassuranceBar from '../components/ReassuranceBar.astro';
import About from '../components/About.astro';
import Odontofobia from '../components/Odontofobia.astro';
import DayClinic from '../components/DayClinic.astro';
import Diferenciais from '../components/Diferenciais.astro';
import Tratamentos from '../components/Tratamentos.astro';
import ClinicGallery from '../components/ClinicGallery.astro';
import Film from '../components/Film.astro';
import Depoimentos from '../components/Depoimentos.astro';
import Localizacao from '../components/Localizacao.astro';
import CtaFinal from '../components/CtaFinal.astro';
import Footer from '../components/Footer.astro';
---
<Layout>
  <span id="top" aria-hidden="true"></span>
  <Header />
  <main>
    <Hero />
    <ReassuranceBar />
    <About />
    <Odontofobia />
    <DayClinic />
    <Diferenciais />
    <Tratamentos />
    <ClinicGallery />
    <Film />
    <Depoimentos />
    <Localizacao />
    <CtaFinal />
  </main>
  <Footer />
</Layout>

<style is:global>#top { position: absolute; top: 0; scroll-margin-top: 0; }</style>

<script>
  // ——— home-only: hero lights-on, Day Clinic scroll-scrub, film lightbox ———
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const conn = (navigator as any).connection || {};
  const saveData = !!conn.saveData || /(^|-)2g/.test(conn.effectiveType || '');

  /* hero lights-on (skip on revisit / reduced-motion / save-data) */
  const hero = document.getElementById('hero');
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  let seen = false;
  try { seen = !!sessionStorage.getItem('akaki_splash_seen'); } catch (e) {}

  if (video) {
    if (saveData || reduce) { try { video.pause(); video.removeAttribute('autoplay'); video.preload = 'none'; } catch (e) {} }
    else {
      const vio = new IntersectionObserver((es) => {
        es.forEach((e) => {
          if (e.isIntersecting) { const p = video.play(); if (p && p.catch) p.catch(() => {}); }
          else { try { video.pause(); } catch (er) {} }
        });
      }, { threshold: 0.08 });
      if (hero) vio.observe(hero);
    }
  }
  if (hero) {
    if (reduce || saveData) hero.classList.add('lit');
    else requestAnimationFrame(() => requestAnimationFrame(() => setTimeout(() => hero.classList.add('lit'), 280)));
  }

  /* Day Clinic scroll-scrub (--p 0→1) */
  const scrub = document.querySelector('[data-scrub]') as HTMLElement | null;
  if (scrub && !reduce) {
    let visible = false, ticking = false;
    const update = () => {
      ticking = false;
      const r = scrub.getBoundingClientRect();
      const total = r.height - window.innerHeight;
      let p = total > 0 ? -r.top / total : (r.top < 0 ? 1 : 0);
      p = Math.min(1, Math.max(0, p));
      scrub.style.setProperty('--p', p.toFixed(3));
    };
    const tick = () => { if (visible && !ticking) { ticking = true; requestAnimationFrame(update); } };
    const sio = new IntersectionObserver((es) => { es.forEach((e) => { visible = e.isIntersecting; if (visible) tick(); }); }, { threshold: 0 });
    sio.observe(scrub);
    window.addEventListener('scroll', tick, { passive: true });
    window.addEventListener('resize', tick, { passive: true });
    update();
  }

  /* Film lightbox */
  const fOpen = document.getElementById('film-open');
  const lb = document.getElementById('film-lightbox');
  const fv = document.getElementById('film-video') as HTMLVideoElement | null;
  const fClose = document.getElementById('film-close');
  const openLb = () => {
    if (!lb) return;
    lb.classList.add('is-open'); lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    if (fv) { const p = fv.play(); if (p && p.catch) p.catch(() => {}); }
  };
  const closeLb = () => {
    if (!lb) return;
    lb.classList.remove('is-open'); lb.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (fv) { try { fv.pause(); } catch (e) {} }
  };
  fOpen && fOpen.addEventListener('click', openLb);
  fClose && fClose.addEventListener('click', closeLb);
  lb && lb.addEventListener('click', (e) => { if (e.target === lb) closeLb(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && lb && lb.classList.contains('is-open')) closeLb(); });
</script>
