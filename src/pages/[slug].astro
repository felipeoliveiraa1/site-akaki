<script>
  const form = document.getElementById('lp-form');
  if (form) {
    const main = document.querySelector('.lp');
    const serviceName = (main && main.getAttribute('data-service')) || 'avaliação';
    const slug = (main && main.getAttribute('data-slug')) || '';
    const getCookie = (n) => { const m = document.cookie.match(new RegExp('(^| )' + n + '=([^;]+)')); return m ? decodeURIComponent(m[2]) : ''; };
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form as HTMLFormElement);
      const nome = String(data.get('nome') || '').trim();
      const tel = String(data.get('telefone') || '').trim();
      let msg = 'Olá! Quero agendar uma avaliação de ' + serviceName + '.';
      if (nome) msg += '\nNome: ' + nome;
      if (tel) msg += '\nTelefone: ' + tel;
      const parts = [];
      const src = getCookie('utm_source'), med = getCookie('utm_medium'), camp = getCookie('utm_campaign');
      if (src) parts.push('Fonte: ' + src);
      if (med) parts.push('Meio: ' + med);
      if (camp) parts.push('Campanha: ' + camp);
      parts.push('Anúncio: ' + slug + '-form');
      msg += ' [' + parts.join(' | ') + ']';
      window.open('https://api.whatsapp.com/send?phone=5511947024607&text=' + encodeURIComponent(msg), '_blank');
    });
  }
</script>
