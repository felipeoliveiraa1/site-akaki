---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { services, google } from '../data/services.js';

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}
const { service: s } = Astro.props;
const WPP = 'https://api.whatsapp.com/send?phone=5511947024607';
const pageTitle = `${s.name} · Akaki Odontologia`;
const pageDesc = s.hero.sub;

const ICONS = {
  cut: '<circle cx="6.5" cy="7" r="2.2"/><circle cx="6.5" cy="17" r="2.2"/><path d="M8.4 8.1l11 7.9M8.4 15.9l11-7.9"/>',
  clock: '<circle cx="12" cy="12" r="8.4"/><path d="M12 7.2V12l3.4 2"/>',
  bite: '<path d="M12 7.2c1.4-2 4.8-2.6 6 .4 1.1 2.9-.8 8-2.9 9.7-1 .8-2.2.8-3.1 0-2.1-1.7-4-6.8-2.9-9.7 1.2-3 4.5-2.4 5.9-.4z"/><path d="M12 7.2c-.1-2 .6-3.6 2.2-4.6"/>',
  smile: '<circle cx="12" cy="12" r="8.4"/><path d="M8.4 14c1 1.4 2.2 2 3.6 2s2.6-.6 3.6-2"/><circle cx="9.2" cy="10" r="0.7" fill="currentColor" stroke="none"/><circle cx="14.8" cy="10" r="0.7" fill="currentColor" stroke="none"/>',
  shield: '<path d="M12 3l7 3v5c0 4.2-2.9 7.6-7 9-4.1-1.4-7-4.8-7-9V6z"/><path d="M9 12l2 2 4-4.2"/>',
  heart: '<path d="M12 20s-7-4.3-7-9.3a4 4 0 0 1 7-2.6 4 4 0 0 1 7 2.6c0 5-7 9.3-7 9.3z"/>',
  ring: '<circle cx="12" cy="12" r="7.6"/><circle cx="12" cy="12" r="3"/>',
  grid: '<rect x="4" y="4" width="6.8" height="6.8" rx="1.6"/><rect x="13.2" y="4" width="6.8" height="6.8" rx="1.6"/><rect x="4" y="13.2" width="6.8" height="6.8" rx="1.6"/><rect x="13.2" y="13.2" width="6.8" height="6.8" rx="1.6"/>',
  crown: '<path d="M4 8.5l4 3 4-6 4 6 4-3-1.6 10.5H5.6z"/>',
  sparkle: '<path d="M12 3l2.1 5.4 5.4 2.1-5.4 2.1L12 18l-2.1-5.4L4.5 10.5l5.4-2.1z"/>',
  tech: '<rect x="3.5" y="5" width="17" height="11" rx="2"/><path d="M9 20h6M12 16v4"/>',
  child: '<circle cx="12" cy="7.5" r="3"/><path d="M5.5 20c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5"/>',
};
const badges = ['CRO-SP 45717', 'EPAO CRO-SP 031012', 'Cirurgia Guiada', 'Atendimento humanizado'];
const arrow = '<path d="M5 12h13"/><path d="M13 6l6 6-6 6"/>';
---
<Layout title={pageTitle} description={pageDesc}>
  <Header />
  <main class="lp" data-slug={s.slug} data-service={s.name}>

    <!-- HERO -->
    <section class="lp-hero">
      <div class="lp-hero__bg" aria-hidden="true"><img src={s.hero.image} alt="" width="1000" height="750" fetchpriority="high" decoding="async" /></div>
      <div class="lp-hero__veil" aria-hidden="true"></div>
      <div class="container lp-hero__grid">
        <div class="lp-hero__text">
          <p class="eyebrow">{s.hero.eyebrow}</p>
          <h1 class="display lp-hero__h1" set:html={s.hero.h1}></h1>
          <p class="lead lp-hero__sub">{s.hero.sub}</p>
          <p class="lp-urgency"><span class="lp-urgency__dot"></span>{s.hero.urgency}</p>
          <a class="btn btn--gold lp-hero__cta" data-wpp={`servico-${s.slug}-hero`} href={WPP} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true" set:html={arrow} /> Agendar minha consulta
          </a>
        </div>

        <form class="lp-form" id="lp-form">
          <p class="lp-form__title">Agende sua consulta</p>
          <input class="lp-form__in" type="text" name="nome" placeholder="Seu nome" autocomplete="name" required />
          <input class="lp-form__in" type="tel" name="telefone" placeholder="Telefone / WhatsApp" autocomplete="tel" required />
          <button class="btn btn--gold lp-form__btn" type="submit">Quero agendar minha consulta</button>
          <p class="lp-form__note">Nossa equipe entra em contato para confirmar sua data e tirar suas dúvidas.</p>
        </form>
      </div>
    </section>

    <!-- STATS -->
    <section class="lp-stats arc-top">
      <div class="container lp-stats__grid">
        {s.stats.map((st, i) => (
          <div class={`lp-stat reveal ${i ? 'lp-stat--div' : ''}`} style={`--d:${i * 70}ms`}>
            <span class="lp-stat__n">{st.n}</span><span class="lp-stat__l">{st.l}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- DIFERENCIAIS -->
    <section class="section lp-dif">
      <div class="container">
        <header class="lp-head">
          <p class="eyebrow eyebrow--center reveal">{s.difEyebrow}</p>
          <h2 class="h2 reveal" style="--d:80ms">{s.difTitle}</h2>
        </header>
        <div class="lp-dif__grid">
          {s.diferenciais.map((d, i) => (
            <article class="lp-card reveal" style={`--d:${i * 90}ms`}>
              <span class="lp-card__n" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <span class="lp-card__rule" aria-hidden="true"></span>
              <h3 class="lp-card__t">{d.t}</h3>
              <p class="lp-card__d">{d.d}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- DOIS PERFIS (opcional) -->
    {s.perfis && (
      <section class="section lp-perfis">
        <div class="container">
          <header class="lp-head">
            <p class="eyebrow eyebrow--center reveal">Para quem é</p>
            <h2 class="h2 reveal" style="--d:80ms">Dois perfis, uma <em>solução</em>.</h2>
          </header>
          <div class="lp-perfis__grid">
            {s.perfis.map((p, i) => (
              <article class={`lp-perfil reveal ${i === 0 ? 'lp-perfil--dark' : ''}`} style={`--d:${i * 110}ms`}>
                <h3 class="lp-perfil__t">{p.title}</h3>
                <p class="lp-perfil__d">{p.body}</p>
                <ul class="lp-perfil__list">{p.items.map((it) => <li>{it}</li>)}</ul>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ESPECIALISTA -->
    <section class="section lp-spec band-cream-deep">
      <div class="container lp-spec__grid">
        <figure class="lp-spec__media reveal">
          <div class="frame-arc"><img src="/assets/dr-akaki.webp" alt="Dr. Luiz Akaki, especialista da Akaki Odontologia" width="640" height="664" loading="lazy" decoding="async" /></div>
        </figure>
        <div class="lp-spec__text">
          <p class="eyebrow reveal">Conheça o especialista</p>
          <h2 class="h2 reveal" style="--d:80ms">Dr. Luiz <em>Akaki</em></h2>
          <p class="lp-spec__role reveal" style="--d:140ms">{s.specRole || 'CRO-SP 45717 · Especialista em Odontologia'}</p>
          <p class="lead lp-spec__bio reveal" style="--d:200ms">{s.specBio || 'Com mais de 35 anos de experiência, o Dr. Luiz Akaki foi pioneiro em trazer técnicas de ponta da Alemanha e dos EUA para o Brasil. Atendimento humanizado, tecnologia de referência e resultados previsíveis.'}</p>
          {s.specQuote && <p class="lp-spec__quote reveal" style="--d:240ms">“{s.specQuote}”</p>}
          <div class="lp-spec__badges reveal" style="--d:280ms">{(s.specBadges || badges).map((b) => <span class="lp-badge">{b}</span>)}</div>
        </div>
      </div>
    </section>

    <!-- PROTOCOLO DE SEGURANÇA (opcional) -->
    {s.protocolo && (
      <section class="section lp-proto band-dark arc-top">
        <div class="container">
          <header class="lp-head">
            <p class="eyebrow eyebrow--center reveal">Segurança</p>
            <h2 class="h2 reveal" style="--d:80ms">Protocolo de segurança da <em>sedação</em>.</h2>
            <p class="lead reveal lp-steps__sub" style="--d:140ms">A sedação odontológica na Akaki segue um protocolo rigoroso em todas as etapas — da avaliação pré-operatória à alta do paciente.</p>
          </header>
          <div class="lp-proto__grid">
            {s.protocolo.map((p, i) => (
              <div class="lp-proto__item reveal" style={`--d:${i * 100}ms`}>
                <span class="lp-step__n">{String(i + 1).padStart(2, '0')}</span>
                <h3 class="lp-proto__t">{p.t}</h3>
                <p class="lp-proto__d">{p.d}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- DEPOIMENTOS -->
    <section class="section lp-revs">
      <div class="container">
        <header class="lp-head">
          <p class="eyebrow eyebrow--center reveal">Resultados</p>
          <h2 class="h2 reveal" style="--d:80ms">O que nossos pacientes <em>dizem</em></h2>
        </header>
        <div class="lp-google reveal">
          <span class="lp-google__g">G</span>
          <span class="lp-google__r">{google.rating}</span>
          <span class="lp-google__stars" aria-hidden="true">★★★★★</span>
          <span class="lp-google__c">Baseado em {google.count} avaliações no Google</span>
        </div>
        <div class="lp-revs__grid">
          {s.testimonials.map((t, i) => (
            <figure class="lp-rev reveal" style={`--d:${i * 90}ms`}>
              <span class="lp-rev__stars" aria-hidden="true">★★★★★</span>
              <blockquote class="lp-rev__q">“{t.q}”</blockquote>
              <figcaption class="lp-rev__by"><span class="lp-rev__av" aria-hidden="true">{t.n.slice(0,1)}</span><span><span class="lp-rev__n">{t.n}</span><span class="lp-rev__l">{t.loc}</span></span></figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- CASOS -->
    <section class="section--tight lp-cases">
      <div class="container">
        <p class="eyebrow eyebrow--center reveal">Casos clínicos</p>
        <div class="lp-cases__grid">
          {s.cases.map((c, i) => (
            <figure class="lp-case reveal" style={`--d:${i * 80}ms`}>
              <div class="lp-case__ba"><span class="lp-case__antes">Antes</span><span class="lp-case__depois">Depois</span></div>
              <figcaption class="lp-case__cap"><span class="lp-case__t">{c.t}</span><span class="lp-case__d">{c.d}</span></figcaption>
            </figure>
          ))}
        </div>
        <p class="lp-cases__note reveal">Imagens ilustrativas — casos reais apresentados na consulta de avaliação.</p>
      </div>
    </section>

    <!-- COMO FUNCIONA -->
    <section class="section lp-steps band-dark arc-top">
      <div class="container">
        <header class="lp-head">
          <p class="eyebrow eyebrow--center reveal">{s.stepsEyebrow}</p>
          <h2 class="h2 reveal" style="--d:80ms">{s.stepsTitle}</h2>
          <p class="lead reveal lp-steps__sub" style="--d:140ms">{s.stepsSub}</p>
        </header>
        <div class="lp-steps__grid">
          {s.steps.map((st, i) => (
            <div class="lp-step reveal" style={`--d:${i * 110}ms`}>
              <span class="lp-step__n">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="lp-step__t">{st.t}</h3>
              <p class="lp-step__d">{st.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- TIPOS -->
    <section class="section lp-types arc-top">
      <div class="container">
        <header class="lp-head">
          <p class="eyebrow eyebrow--center reveal">{s.typesEyebrow}</p>
          <h2 class="h2 reveal" style="--d:80ms">{s.typesTitle}</h2>
        </header>
        <div class="lp-types__grid">
          {s.types.map((t, i) => (
            <article class="lp-type reveal" style={`--d:${i * 90}ms`}>
              <span class="lp-ic lp-ic--ring" aria-hidden="true"><svg viewBox="0 0 24 24" set:html={ICONS[t.icon] || ICONS.ring} /></span>
              <h3 class="lp-type__t">{t.t}</h3>
              <p class="lp-type__d">{t.d}</p>
              <a class="lp-type__cta" data-wpp={`servico-${s.slug}-tipo`} href={WPP} target="_blank" rel="noopener noreferrer">Agendar consulta <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 16L16 8"/><path d="M9 8h7v7"/></svg></a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- COMPARATIVO -->
    <section class="section lp-cmp">
      <div class="container">
        <header class="lp-head">
          <p class="eyebrow eyebrow--center reveal">{s.compare.eyebrow}</p>
          <h2 class="h2 reveal" style="--d:80ms">{s.compare.title}</h2>
        </header>
        <div class="lp-cmp__grid reveal">
          <div class="lp-cmp__col lp-cmp__col--bad">
            <div class="lp-cmp__top"><span class="lp-cmp__h">{s.compare.leftTitle}</span><span class="lp-cmp__tag">{s.compare.leftTag}</span></div>
            <p class="lp-cmp__sub">{s.compare.leftSub}</p>
            <ul>{s.compare.left.map((it) => (<li><span class="lp-cmp__x" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M7 7l10 10M17 7L7 17"/></svg></span><span><strong>{it.t}</strong>{it.d}</span></li>))}</ul>
          </div>
          <div class="lp-cmp__col lp-cmp__col--good">
            <div class="lp-cmp__top"><span class="lp-cmp__h">{s.compare.rightTitle}</span><span class="lp-cmp__tag lp-cmp__tag--gold">{s.compare.rightTag}</span></div>
            <p class="lp-cmp__sub">{s.compare.rightSub}</p>
            <ul>{s.compare.right.map((it) => (<li><span class="lp-cmp__check" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 12.5l4.5 4.5L19 7"/></svg></span><span><strong>{it.t}</strong>{it.d}</span></li>))}</ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section lp-faq band-cream-deep">
      <div class="container lp-faq__wrap">
        <header class="lp-head">
          <p class="eyebrow eyebrow--center reveal">Dúvidas frequentes</p>
          <h2 class="h2 reveal" style="--d:80ms">Perguntas frequentes</h2>
        </header>
        <div class="lp-faq__list">
          {s.faq.map((f, i) => (
            <details class="lp-faq__item reveal" style={`--d:${i * 60}ms`}>
              <summary>{f.q}<span class="lp-faq__plus" aria-hidden="true"></span></summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="lp-final band-dark arc-top">
      <div class="container lp-final__inner">
        <p class="eyebrow eyebrow--center reveal">Próximo passo</p>
        <h2 class="display lp-final__h reveal" style="--d:80ms">Agende sua consulta de <em>avaliação</em>.</h2>
        <p class="lead reveal lp-final__sub" style="--d:140ms">Nossa equipe entra em contato para confirmar sua data e tirar suas dúvidas.</p>
        <div class="lp-final__cta reveal" style="--d:200ms">
          <a class="btn btn--gold" data-wpp={`servico-${s.slug}-final`} href={WPP} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true" set:html={arrow} /> Quero agendar minha consulta
          </a>
          <a class="btn btn--light" href="/#localizacao">Falar com a clínica</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* HERO — cinematic, treated photo + veil */
  .lp-hero { position: relative; overflow: hidden; background: var(--cinema-black); color: var(--white-text); padding: calc(var(--nav-h) + clamp(44px, 8vh, 96px)) 0 clamp(88px, 14vh, 160px); isolation: isolate; }
  .lp-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .lp-hero__bg img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.42) saturate(0.82) blur(3px); transform: scale(1.08); animation: kenburns 24000ms var(--breath) infinite alternate; }
  .lp-hero__veil { position: absolute; inset: 0; z-index: 1; background: radial-gradient(120% 100% at 25% 35%, rgba(11,14,19,0.3) 0%, rgba(11,14,19,0.72) 70%, rgba(11,14,19,0.88) 100%), linear-gradient(180deg, rgba(11,14,19,0.7) 0%, rgba(11,14,19,0.45) 50%, rgba(11,14,19,0.92) 100%); }
  .lp-hero__grid { position: relative; z-index: 2; display: grid; grid-template-columns: 1.3fr 0.7fr; gap: clamp(32px, 4.5vw, 72px); align-items: center; }
  .lp-hero .eyebrow { color: var(--gold-light); }
  .lp-hero__h1 { color: var(--white-text); font-size: clamp(34px, 5.2vw, 60px); margin: 18px 0 20px; max-width: 16ch; }
  .lp-hero__h1 em { color: var(--gold-light); font-style: italic; }
  .lp-hero__sub { color: rgba(245,240,232,0.82); max-width: 50ch; }
  .lp-urgency { display: inline-flex; align-items: center; gap: 10px; margin: 26px 0 28px; padding: 13px 18px; border: 1px solid rgba(211,164,108,0.4); border-radius: 12px; background: rgba(211,164,108,0.08); font-size: 13px; color: rgba(245,240,232,0.9); }
  .lp-urgency__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--gold); flex: 0 0 auto; animation: pulse 2.4s var(--breath) infinite; }
  @keyframes pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(211,164,108,0.5); } 50% { box-shadow: 0 0 0 7px rgba(211,164,108,0); } }
  .lp-hero__cta svg { width: 16px; height: 16px; }

  .lp-form { background: rgba(11,14,19,0.55); border: 1px solid rgba(211,164,108,0.3); border-radius: 20px; padding: clamp(24px, 2.6vw, 34px); display: flex; flex-direction: column; gap: 13px; -webkit-backdrop-filter: blur(14px); backdrop-filter: blur(14px); box-shadow: 0 30px 70px -40px rgba(0,0,0,0.8); }
  .lp-form__title { font-family: var(--sans); font-weight: 600; font-size: 11px; letter-spacing: 0.24em; text-transform: uppercase; color: var(--gold-light); text-align: center; margin-bottom: 4px; }
  .lp-form__in { width: 100%; padding: 14px 16px; border-radius: 11px; border: 1px solid rgba(244,238,227,0.22); background: rgba(11,14,19,0.4); color: var(--cream); font-family: var(--body); font-size: 14.5px; }
  .lp-form__in::placeholder { color: rgba(245,240,232,0.45); }
  .lp-form__btn { width: 100%; justify-content: center; margin-top: 4px; }
  .lp-form__note { font-size: 11.5px; color: rgba(245,240,232,0.55); text-align: center; line-height: 1.5; }

  /* STATS — cream band, gold serif numbers, hairline dividers */
  .lp-stats { background: var(--cream); position: relative; z-index: 2; }
  .lp-stats__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; padding-block: clamp(34px, 4.6vh, 56px); }
  .lp-stat { text-align: center; position: relative; }
  .lp-stat--div::before { content: ""; position: absolute; left: -8px; top: 50%; transform: translateY(-50%); width: 1px; height: 46px; background: rgba(211,164,108,0.4); }
  .lp-stat__n { display: block; font-family: var(--serif); font-weight: 400; font-variation-settings: 'opsz' 144; font-size: clamp(30px, 3.6vw, 50px); color: var(--gold-dark); line-height: 1; letter-spacing: -0.01em; }
  .lp-stat__l { display: block; font-family: var(--sans); font-weight: 600; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--navy-ghost); margin-top: 10px; }

  .lp-head { text-align: center; max-width: 34ch; margin: 0 auto clamp(38px, 5.4vh, 62px); }
  .lp-head .h2 { margin-top: 14px; }
  .lp-head .h2 em { font-style: italic; color: var(--gold-dark); }
  .lp-head .lead { margin-top: 16px; }

  /* premium translucent cards */
  .lp-dif { background: var(--cream); }
  .lp-dif__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(16px, 1.8vw, 24px); }
  .lp-card { background: rgba(255,255,255,0.5); border: 1px solid rgba(24,39,60,0.1); border-radius: 20px; padding: clamp(28px, 2.8vw, 38px); transition: transform 340ms var(--silk), box-shadow 340ms var(--silk), border-color 340ms var(--silk); }
  .lp-card__n { display: block; font-family: var(--serif); font-style: italic; font-weight: 400; font-variation-settings: 'opsz' 144; font-size: clamp(30px, 3vw, 42px); line-height: 1; color: var(--gold-dark); letter-spacing: -0.02em; }
  .lp-card__rule { display: block; width: 34px; height: 2px; border-radius: 2px; background: var(--brass); margin: 16px 0 18px; transition: width 420ms var(--silk); }
  .lp-card__t { font-family: var(--serif); font-weight: 400; font-variation-settings: 'opsz' 144; font-size: clamp(19px, 2vw, 23px); color: var(--navy); margin-bottom: 10px; letter-spacing: -0.01em; }
  .lp-card__d { font-family: var(--body); font-size: 13.5px; line-height: 1.62; color: var(--navy-soft); }
  /* generic line-icon (tipos) */
  .lp-ic { display: inline-grid; place-items: center; width: 50px; height: 50px; color: var(--gold-dark); margin-bottom: 18px; }
  .lp-ic svg { width: 30px; height: 30px; fill: none; stroke: currentColor; stroke-width: 1.4; stroke-linecap: round; stroke-linejoin: round; }
  .lp-ic--ring { border: 1.5px solid rgba(211,164,108,0.45); border-radius: 50%; }
  @media (hover: hover) { .lp-card:hover { transform: translateY(-5px); box-shadow: 0 26px 50px -30px rgba(24,39,60,0.42); border-color: rgba(211,164,108,0.4); } .lp-card:hover .lp-card__rule { width: 56px; } }

  /* especialista quote + perfis + protocolo */
  .lp-spec__quote { font-family: var(--serif); font-style: italic; font-variation-settings: 'opsz' 144; font-size: clamp(15px, 1.7vw, 18px); line-height: 1.5; color: var(--gold-dark); border-left: 2px solid var(--gold); padding-left: 16px; margin: 20px 0 4px; max-width: 50ch; }

  .lp-perfis { background: var(--cream); }
