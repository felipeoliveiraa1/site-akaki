---
// headline words for the word-by-word polish reveal
const pre = ['Você', 'dorme', 'e', 'acorda', 'com', 'um'];
const gold = ['sorriso', 'novo.'];
let i = 0;
---
<section id="hero" class="hero">
  <video
    class="hero__video"
    id="hero-video"
    poster="/assets/hero-poster.webp"
    muted autoplay loop playsinline preload="metadata"
    disablepictureinpicture aria-hidden="true"
  >
    <source src="/assets/akaki-loop.webm" type="video/webm" />
    <source src="/assets/akaki-loop.mp4" type="video/mp4" />
  </video>
  <div class="hero__veil" aria-hidden="true"></div>

  <div class="hero__inner container">
    <p class="eyebrow hero__eyebrow">Clínica pioneira em odontofobia · Jardins — SP</p>

    <h1 class="display hero__title words" aria-label="Você dorme e acorda com um sorriso novo.">
      {pre.map((w) => <Fragment><span class="word" style={`--wd:${(i++) * 90}ms`}>{w}</span>{' '}</Fragment>)}
      <em>{gold.map((w) => <Fragment><span class="word ember-on" style={`--wd:${(i++) * 90}ms`}>{w}</span>{' '}</Fragment>)}</em>
    </h1>

    <p class="lead hero__sub">Tratamento odontológico com sedação consciente — em menos tempo e sem medo.</p>

    <div class="hero__cta">
      <a class="btn btn--primary hero__primary" data-wpp="hero-agendar" href="https://api.whatsapp.com/send?phone=5511947024607" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h13"/><path d="M13 6l6 6-6 6"/></svg>
        Agende sua avaliação
      </a>
      <a class="btn btn--light" href="#film">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5l11 7-11 7z"/></svg>
        Veja nosso filme
      </a>
    </div>

    <p class="hero__seal">Sedação consciente · Total segurança · Day&nbsp;Clinic</p>
  </div>

  <a class="hero__cue" href="#about" aria-label="Rolar para descobrir">
    <span class="hero__cue-line"></span>
    <span class="hero__cue-label">role para descer</span>
  </a>
</section>

<style>
  .hero {
    position: relative; min-height: 100svh; overflow: hidden;
    display: flex; align-items: flex-end;
    background: var(--cinema-black); color: var(--white-text);
    padding: calc(var(--nav-h) + 24px) 0 clamp(96px, 15vh, 150px);
    isolation: isolate;
  }
  .hero__video {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0;
    transform: scale(1.07);
    filter: brightness(0.34) saturate(0.82) blur(10px);
    transition: filter 1400ms var(--silk);
  }
  .hero.lit .hero__video { filter: brightness(0.6) saturate(0.86) blur(4px); animation: kenburns 22000ms var(--breath) infinite alternate; }
  .hero__veil {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background:
      radial-gradient(130% 100% at 28% 38%, rgba(11,14,19,0.2) 0%, rgba(11,14,19,0.66) 70%, rgba(11,14,19,0.82) 100%),
      linear-gradient(180deg, rgba(11,14,19,0.82) 0%, rgba(11,14,19,0.5) 46%, rgba(11,14,19,0.9) 100%);
  }
  .hero__inner { position: relative; z-index: 2; width: 100%; }

  .hero__leaf { display: inline-block; width: 40px; height: 46px; margin-bottom: 22px; }
  .hero__leaf :global(svg) { width: 100%; height: 100%; overflow: visible; }
  .hero__leaf :global(.leaf-stroke) { stroke-dasharray: 1; stroke-dashoffset: 1; }
  .hero.lit .hero__leaf :global(.leaf-stroke) { animation: draw 1700ms var(--ink) 200ms forwards; }

  .hero__eyebrow { color: var(--gold-light); margin-bottom: 22px; }
  .hero__title { max-width: 15ch; color: var(--white-text); margin-bottom: 26px; }
  .hero__title em { font-style: italic; color: var(--gold-light); }
  .hero.lit .ember-on { animation: ember 1100ms ease-out 1100ms 1; }

  .hero__sub { color: rgba(245,240,232,0.84); max-width: 44ch; margin-bottom: 34px; }

  .hero__cta { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
  .hero__primary { box-shadow: 0 14px 40px -12px rgba(211,164,108,0.6), 0 3px 10px rgba(11,14,19,0.3); animation: cta-glow 5500ms var(--breath) infinite alternate; }
  @keyframes cta-glow {
    from { box-shadow: 0 14px 40px -14px rgba(211,164,108,0.42), 0 3px 10px rgba(11,14,19,0.3); }
    to   { box-shadow: 0 18px 54px -10px rgba(211,164,108,0.78), 0 3px 10px rgba(11,14,19,0.3); }
  }
  .hero__primary svg { width: 16px; height: 16px; }
  .hero__cta .btn--light svg { width: 14px; height: 14px; fill: currentColor; stroke: none; }

  .hero__seal {
    margin-top: 30px; font-family: var(--sans); font-weight: 600; font-size: 10.5px;
    letter-spacing: 0.24em; text-transform: uppercase; color: rgba(228,188,138,0.72);
  }

  /* entrance for sub + ctas + seal (after lit) */
  .hero__sub, .hero__cta, .hero__seal { opacity: 0; transform: translateY(16px); }
  .hero.lit .hero__sub { animation: hero-in 700ms var(--silk) 1200ms forwards; }
  .hero.lit .hero__cta { animation: hero-in 700ms var(--tactile) 1500ms forwards; }
  .hero.lit .hero__seal { animation: hero-in 700ms var(--silk) 1750ms forwards; }
  @keyframes hero-in { to { opacity: 1; transform: none; } }

  .hero__cue {
    position: absolute; left: 50%; bottom: 26px; transform: translateX(-50%); z-index: 2;
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    color: rgba(245,240,232,0.55);
  }
  .hero__cue-line { width: 1px; height: 40px; background: linear-gradient(var(--gold), transparent); animation: cue 2400ms var(--breath) infinite; }
  @keyframes cue { 0%,100% { opacity: 0.4; transform: scaleY(0.7); transform-origin: top; } 50% { opacity: 1; transform: scaleY(1); } }
  .hero__cue-label { font-family: var(--sans); font-weight: 600; font-size: 9px; letter-spacing: 0.28em; text-transform: uppercase; }

  @media (max-width: 640px) { .hero__cue-label { display: none; } }

  @media (prefers-reduced-motion: reduce) {
    .hero__video { filter: brightness(0.7) saturate(0.9); }
    .hero__sub, .hero__cta, .hero__seal { opacity: 1; transform: none; animation: none; }
    .hero__primary { animation: none; }
  }
</style>
