---
import Wordmark from './Wordmark.astro';
const nav = [
  { href: '/#about', label: 'Sobre' },
  { href: '/sedacao-odontologica', label: 'Sedação Odontológica' },
  { href: '/implantes', label: 'Implantes' },
  { href: '/ortodontia', label: 'Ortodontia' },
  { href: '/estetica', label: 'Estética' },
  { href: '/odontopediatria', label: 'Odontopediatria' },
  { href: '/#film', label: 'O Filme' },
];
const year = new Date().getFullYear();
---
<footer class="ft band-dark">
  <div class="container ft__grid">
    <div class="ft__brand">
      <a class="wordmark ft__word" href="#top" aria-label="Akaki Odontologia">
        <Wordmark />
        <span class="wordmark__shine" id="ft-shine" aria-hidden="true"></span>
      </a>
      <p class="ft__tag">Clínica pioneira em odontofobia · sedação consciente · Jardim&nbsp;América, SP</p>
      <a class="btn btn--gold ft__cta" data-wpp="footer-agendar" href="https://api.whatsapp.com/send?phone=5511947024607" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h13"/><path d="M13 6l6 6-6 6"/></svg>
        Agende sua avaliação
      </a>
    </div>

    <nav class="ft__nav" aria-label="Navegação do rodapé">
      <span class="ft__h">Navegue</span>
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
    </nav>

    <div class="ft__contact">
      <span class="ft__h">Contato</span>
      <a href="https://api.whatsapp.com/send?phone=5511947024607" data-wpp="footer-canal" target="_blank" rel="noopener noreferrer">WhatsApp · (11) 94702-4607</a>
      <a href="https://www.instagram.com/akakiodontologia/" target="_blank" rel="noopener noreferrer">Instagram · @akakiodontologia</a>
      <a href="tel:+551132667921">(11) 3266-7921</a>
      <a href="https://www.youtube.com/channel/UCyGQUid86fGgsJoGISGSuGQ" target="_blank" rel="noopener noreferrer">YouTube</a>
      <a href="mailto:akakiodonto@gmail.com">akakiodonto@gmail.com</a>
      <p class="ft__nap">Rua Estados Unidos, 205 — Jardim&nbsp;Paulista<br />São&nbsp;Paulo – SP · 01427-002</p>
    </div>
  </div>

  <div class="container ft__legal">
    <span>© {year} Akaki Odontologia · EPAO CRO-SP 13012 · Resp. Téc. Dr.&nbsp;Luiz&nbsp;Akaki — CRO-SP&nbsp;45717</span>
    <span>Tratamento odontológico com sedação consciente.</span>
  </div>
</footer>

<style>
  .ft { padding-top: clamp(56px, 8vh, 96px); padding-bottom: 30px; position: relative; }
  .ft::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(211,164,108,0.4), transparent); }
  .ft__grid { display: grid; grid-template-columns: 1.4fr 0.8fr 1fr; gap: clamp(30px, 4vw, 64px); }

  .ft__word { width: clamp(150px, 16vw, 190px); color: var(--gold); display: inline-block; }
  .ft__tag { font-family: var(--body); font-weight: 300; font-size: 13.5px; line-height: 1.6; color: rgba(245,240,232,0.62); margin: 20px 0 22px; max-width: 36ch; }
  .ft__cta { padding: 13px 22px; font-size: 12.5px; }
  .ft__cta svg { width: 15px; height: 15px; }

  .ft__h { display: block; font-family: var(--sans); font-weight: 600; font-size: 10px; letter-spacing: 0.26em; text-transform: uppercase; color: var(--gold-light); margin-bottom: 16px; }
  .ft__nav { display: flex; flex-direction: column; gap: 11px; }
  .ft__nav a, .ft__contact a {
    font-family: var(--body); font-size: 13.5px; color: rgba(245,240,232,0.72);
    width: fit-content; position: relative; transition: color 240ms var(--silk);
  }
  .ft__nav a:hover, .ft__contact a:hover { color: var(--gold-light); }
  .ft__contact { display: flex; flex-direction: column; gap: 11px; }
  .ft__nap { font-family: var(--body); font-size: 13px; color: rgba(245,240,232,0.5); line-height: 1.5; margin-top: 6px; }

  .ft__legal {
    display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap;
    margin-top: clamp(44px, 6vh, 72px); padding-top: 22px; border-top: 1px solid rgba(245,240,232,0.1);
    font-family: var(--body); font-size: 11.5px; color: rgba(245,240,232,0.42); letter-spacing: 0.02em;
  }

  @media (max-width: 820px) {
    .ft__grid { grid-template-columns: 1fr 1fr; }
    .ft__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .ft__grid { grid-template-columns: 1fr; }
    .ft__legal { flex-direction: column; gap: 6px; }
  }
</style>
