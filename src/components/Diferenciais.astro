---
const cards = [
  {
    t: 'Multidisciplinar',
    b: 'Equipe completa e especializada em Implantodontia, Ortodontia, Reabilitação Oral, Endodontia, Odontopediatria, Cirurgia Oral, Traumatologia Buco-maxilo-facial e Anestesia.',
    icon: '<circle cx="8.5" cy="9" r="2.6"/><circle cx="15.5" cy="9" r="2.6"/><path d="M4 18.5c0-2.7 2-4.6 4.5-4.6 1.2 0 2.3.4 3 1.1"/><path d="M12.5 15c.8-.7 1.9-1.1 3-1.1 2.5 0 4.5 1.9 4.5 4.6"/>',
  },
  {
    t: 'Dentista com sedação',
    b: 'Todo o tratamento é feito através de sedação consciente, com total segurança, rapidez e qualidade.',
    icon: '<path d="M20.5 14.8A8.4 8.4 0 0 1 9.2 3.5 8.4 8.4 0 1 0 20.5 14.8z"/><path d="M15.5 4.5l.7 1.6 1.6.7-1.6.7-.7 1.6-.7-1.6-1.6-.7 1.6-.7z"/>',
  },
  {
    t: 'Técnicas e tecnologia',
    b: 'Tecnologia de ponta para um diagnóstico completo e um tratamento de qualidade. Todos os especialistas atualizados com as mais recentes técnicas da odontologia.',
    icon: '<path d="M6.5 3.5h11l3 5-8.5 12-8.5-12z"/><path d="M3.5 8.5h17"/><path d="M9.5 3.5l-1.5 5 4 12 4-12-1.5-5"/>',
  },
];
---
<section id="diferenciais" class="section dif">
  <span class="thread dif__thread reveal" aria-hidden="true"></span>
  <div class="container">
    <header class="dif__head">
      <p class="eyebrow eyebrow--center reveal">Por que a Akaki</p>
      <h2 class="h2 reveal" style="--d:80ms">Autoridade médica, em <em>três pilares</em>.</h2>
    </header>

    <div class="dif__grid">
      {cards.map((c, idx) => (
        <article class="dif__card reveal" style={`--d:${idx * 120}ms`}>
          <span class="dif__icon" aria-hidden="true"><svg viewBox="0 0 24 24" set:html={c.icon} /></span>
          <h3 class="dif__t">{c.t}</h3>
          <p class="dif__b">{c.b}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .dif { background: var(--cream); position: relative; }
  .dif__thread { position: absolute; top: clamp(34px, 5vh, 60px); left: 50%; transform: translateX(-50%); }
  .dif__head { text-align: center; max-width: 30ch; margin: 0 auto clamp(42px, 6vh, 70px); }
  .dif__head .h2 { margin-top: 16px; }

  .dif__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(18px, 2.4vw, 30px); }
  .dif__card {
    background: rgba(255,255,255,0.4);
    border: 1px solid rgba(24,39,60,0.10);
    border-radius: 20px;
    padding: clamp(26px, 3vw, 38px);
    transition: transform 340ms var(--silk), box-shadow 340ms var(--silk), border-color 340ms var(--silk);
  }
  .dif__icon { display: inline-grid; place-items: center; width: 46px; height: 46px; color: var(--gold-dark); margin-bottom: 22px; }
  .dif__icon svg { width: 100%; height: 100%; fill: none; stroke: currentColor; stroke-width: 1.4; stroke-linecap: round; stroke-linejoin: round; }
  .dif__t { font-family: var(--serif); font-weight: 400; font-variation-settings: 'opsz' 144; font-size: clamp(20px, 2.2vw, 25px); color: var(--navy); margin-bottom: 14px; letter-spacing: -0.01em; }
  .dif__b { font-family: var(--body); font-weight: 400; font-size: 14.5px; line-height: 1.62; color: var(--navy-soft); }

  @media (hover: hover) {
    .dif__card:hover { transform: translateY(-5px); box-shadow: 0 26px 50px -28px rgba(24,39,60,0.4); border-color: rgba(211,164,108,0.4); }
    .dif__card:hover .dif__icon { color: var(--gold); filter: drop-shadow(0 2px 10px rgba(211,164,108,0.4)); transition: color 340ms, filter 340ms; }
  }
  @media (max-width: 860px) { .dif__grid { grid-template-columns: 1fr; max-width: 480px; margin-inline: auto; } }
</style>
