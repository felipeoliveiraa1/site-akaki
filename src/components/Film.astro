---
---
<section id="film" class="section film band-dark arc-top">
  <div class="container film__inner">
    <header class="film__head">
      <p class="eyebrow eyebrow--center reveal">O Filme</p>
      <h2 class="h2 reveal" style="--d:80ms">Conheça um pouco da <em>Akaki</em>.</h2>
      <p class="lead reveal" style="--d:160ms">Veja nosso vídeo — alguns minutos com o Dr.&nbsp;Luiz&nbsp;Akaki e a clínica por dentro.</p>
    </header>

    <button class="film__player reveal" id="film-open" style="--d:200ms" aria-label="Assistir ao filme da Akaki">
      <img src="/assets/film-poster.webp" alt="" width="1280" height="720" loading="lazy" decoding="async" />
      <span class="film__veil" aria-hidden="true"></span>
      <span class="film__play" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="M8 5l12 7-12 7z"/></svg>
      </span>
    </button>
  </div>
</section>

<div class="film__lightbox" id="film-lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Filme da Akaki">
  <button class="film__close" id="film-close" aria-label="Fechar">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
  </button>
  <div class="film__stage">
    <video id="film-video" class="film__video" controls playsinline preload="none" poster="/assets/film-poster.webp">
      <source src="/assets/akaki-film.mp4" type="video/mp4" />
    </video>
  </div>
</div>

<style>
  .film { position: relative; text-align: center; z-index: 3; }
  .film__head { max-width: 40ch; margin: 0 auto clamp(34px, 5vh, 56px); }
  .film__head .h2 { margin: 16px 0 16px; }
  .film__head .lead { color: rgba(245,240,232,0.78); }

  .film__player {
    position: relative; display: block; width: 100%; max-width: 1000px; margin: 0 auto;
    aspect-ratio: 16 / 9; border: 0; padding: 0; cursor: pointer; background: var(--cinema-black);
    border-radius: 22px; overflow: hidden;
    box-shadow: 0 36px 90px -40px rgba(0,0,0,0.8), inset 0 0 0 1px rgba(211,164,108,0.22);
  }
  .film__player img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.74) saturate(0.9); transition: transform 800ms var(--silk), filter 800ms var(--silk); }
  .film__veil { position: absolute; inset: 0; background: radial-gradient(60% 60% at 50% 50%, transparent, rgba(11,14,19,0.45)); }
  .film__play {
    position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
    width: clamp(64px, 9vw, 92px); height: clamp(64px, 9vw, 92px);
    display: grid; place-items: center; border-radius: 50%;
    background: rgba(11,14,19,0.4); border: 1.5px solid var(--gold);
    -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px);
    color: var(--gold-light);
    animation: play-glow 5500ms var(--breath) infinite alternate;
    transition: transform 320ms var(--tactile), background-color 320ms var(--silk);
  }
  .film__play svg { width: 38%; height: 38%; fill: currentColor; stroke: none; margin-left: 8%; }
  @keyframes play-glow {
    from { box-shadow: 0 0 0 0 rgba(211,164,108,0); }
    to   { box-shadow: 0 0 36px -4px rgba(211,164,108,0.55); }
  }
  @media (hover: hover) {
    .film__player:hover img { transform: scale(1.04); filter: brightness(0.84); }
    .film__player:hover .film__play { transform: translate(-50%, -50%) scale(1.08); background: var(--gold); color: var(--cinema-black); }
  }

  /* lightbox */
  .film__lightbox {
    position: fixed; inset: 0; z-index: 200; display: none; place-items: center;
    padding: clamp(16px, 4vw, 48px);
    background: rgba(7,9,12,0.92); -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
    opacity: 0; transition: opacity 420ms var(--exhale);
  }
  .film__lightbox.is-open { display: grid; opacity: 1; }
  .film__stage { width: 100%; max-width: 1100px; aspect-ratio: 16 / 9; border-radius: 16px; overflow: hidden; box-shadow: 0 40px 120px -30px rgba(0,0,0,0.9); }
  .film__video { width: 100%; height: 100%; background: #000; display: block; }
  .film__close {
    position: absolute; top: clamp(14px, 3vw, 28px); right: clamp(14px, 3vw, 28px);
    width: 46px; height: 46px; border-radius: 50%; cursor: pointer;
    background: rgba(244,238,227,0.1); border: 1px solid rgba(244,238,227,0.4); color: var(--cream);
    display: grid; place-items: center; transition: background-color 240ms, transform 240ms var(--silk);
  }
  .film__close svg { width: 20px; height: 20px; fill: none; stroke: currentColor; stroke-width: 1.7; stroke-linecap: round; }
  .film__close:hover { background: var(--gold); color: var(--cinema-black); transform: rotate(90deg); }

  @media (prefers-reduced-motion: reduce) { .film__play { animation: none; } }
</style>
