---
const items = [
  { t: '35 anos de história', icon: '<path d="M12 3l7 3v5c0 4.2-2.9 7.6-7 9-4.1-1.4-7-4.8-7-9V6z"/><path d="M9 12l2 2 4-4.2"/>' },
  { t: '+5.000 implantes', icon: '<circle cx="8" cy="9.5" r="2.4"/><circle cx="16" cy="9.5" r="2.4"/><path d="M3.5 19c0-2.6 2-4.4 4.5-4.4S12.5 16.4 12.5 19"/><path d="M11.5 19c0-2.6 2-4.4 4.5-4.4S20.5 16.4 20.5 19"/>' },
  { t: '4.9 no Google', icon: '<path d="M12 3l2.1 5.3L19.5 9l-4.2 3.4L16.7 18 12 14.9 7.3 18l1.4-5.6L4.5 9l5.4-.7z"/>' },
  { t: 'Day Clinic em 1 dia', icon: '<circle cx="12" cy="12" r="8.2"/><path d="M12 7.4V12l3 2"/>' },
];
---
<section class="reassure band-navy" aria-label="Diferenciais de confiança">
  <span class="thread reassure__thread reveal" aria-hidden="true"></span>
  <div class="reassure__inner container">
    {items.map((it, idx) => (
      <div class="reassure__item reveal" style={`--d:${idx * 90}ms`}>
        <span class="reassure__icon" aria-hidden="true"><svg viewBox="0 0 24 24" set:html={it.icon} /></span>
        <span class="reassure__t">{it.t}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .reassure { position: relative; padding: clamp(26px, 4vh, 40px) 0 clamp(52px, 7.5vh, 80px); }
  .reassure__thread { position: absolute; top: 0; left: 50%; transform: translateX(-50%); }
  .reassure__inner {
    display: grid; grid-template-columns: repeat(4, max-content);
    justify-content: center; align-items: center; column-gap: clamp(24px, 4vw, 64px);
  }
  .reassure__item { display: flex; align-items: center; gap: 11px; position: relative; min-width: 0; }
  .reassure__item:not(:first-child)::before {
    content: ""; position: absolute; left: calc(-1 * clamp(12px, 2vw, 32px)); top: 50%; transform: translateY(-50%);
    width: 1px; height: 24px; background: rgba(211,164,108,0.3);
  }
  .reassure__icon { flex: 0 0 auto; width: 24px; height: 24px; color: var(--gold-light); }
  .reassure__icon svg { width: 100%; height: 100%; fill: none; stroke: currentColor; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .reassure__t {
    font-family: var(--sans); font-weight: 600; font-size: clamp(10.5px, 1.05vw, 12px);
    letter-spacing: 0.1em; text-transform: uppercase; line-height: 1.3; color: var(--cream); white-space: nowrap;
  }

  /* tablet → 2×2, sem divisórias */
  @media (max-width: 1040px) {
    .reassure__inner { grid-template-columns: repeat(2, max-content); justify-content: center; row-gap: 18px; column-gap: clamp(40px, 8vw, 90px); }
    .reassure__item:not(:first-child)::before { display: none; }
  }
  /* mobile → 2×2 com ícone em badge dourado + texto centralizado */
  @media (max-width: 520px) {
    .reassure { padding: clamp(28px, 5vh, 40px) 0 clamp(40px, 6vh, 60px); }
    .reassure__inner { grid-template-columns: 1fr 1fr; row-gap: clamp(24px, 5vw, 32px); column-gap: 14px; justify-items: center; }
    .reassure__item { flex-direction: column; align-items: center; text-align: center; gap: 12px; }
    .reassure__icon {
      width: 48px; height: 48px; display: grid; place-items: center;
      border: 1px solid rgba(211,164,108,0.4); border-radius: 50%;
      background: rgba(211,164,108,0.06);
    }
    .reassure__icon svg { width: 22px; height: 22px; }
    .reassure__t { font-size: 11px; line-height: 1.35; max-width: 15ch; white-space: normal; }
  }
</style>
